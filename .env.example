# ============================================================
#  AI 大模型（选一个填 API Key 即可）
#  AI_PROVIDER 可选: deepseek | gemini | openai | kimi | grok | glm | claude
# ============================================================
AI_PROVIDER=deepseek
AI_API_KEY=
# AI_MODEL 留空则使用默认模型，填了则覆盖
AI_MODEL=
# AI_BASE_URL 留空则使用默认地址，填了则覆盖（代理/中转场景）
AI_BASE_URL=

# ============================================================
#  和风天气 JWT 认证（免费 1000 次/天）
#  1. 生成密钥对: openssl genpkey -algorithm ed25519 -out hefeng_private.pem
#  2. 提取公钥:   openssl pkey -in hefeng_private.pem -pubout -out hefeng_public.pem
#  3. 上传公钥到 https://console.qweather.com 凭据管理
#  4. 在控制台-项目管理查看 Project ID 和 Credential ID
#  5. 在控制台-设置查看 API Host，形如 https://abc1234xyz.def.qweatherapi.com
#  6. 空气质量 API 使用经纬度路径参数，广州可填 23.13,113.26
#  7. 将私钥内容填到下方（去掉 PEM 头尾，合并为一行 base64）
# ============================================================
HEFENG_API_HOST=
HEFENG_PROJECT_ID=
HEFENG_CREDENTIAL_ID=
HEFENG_AIR_COORDINATES=
HEFENG_PRIVATE_KEY=

# ============================================================
#  以下通常无需修改
# ============================================================
BOT_SERVER_PORT=8080
ML_SERVER_PORT=5000
CHROMA_PERSIST_DIR=./ml-server/chroma_data
EMBED_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# ============================================================
#  微信 iLink 网关（Python 版）
#  先启动 bot-server，再运行: python ml-server/run_weixin_gateway.py
# ============================================================
WEIXIN_ILINK_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
WEIXIN_ILINK_APP_ID=bot
WEIXIN_BOT_TYPE=3
WEIXIN_CHANNEL_VERSION=2.4.3
WEIXIN_BOT_AGENT=hotspot-bot/1.0
WEIXIN_ASSISTANT_API_URL=http://localhost:8080/api/assistant/chat
WEIXIN_STATE_DIR=./ml-server/storage/weixin_gateway
WEIXIN_API_TIMEOUT_SECONDS=15
WEIXIN_LONG_POLL_TIMEOUT_SECONDS=35
WEIXIN_QR_POLL_TIMEOUT_SECONDS=35
WEIXIN_MAX_CONSECUTIVE_FAILURES=5
WEIXIN_RETRY_DELAY_SECONDS=2
WEIXIN_BACKOFF_DELAY_SECONDS=30

# 新闻卡片 PNG 输出目录，留空则默认写到系统临时目录
BOT_NEWS_CARD_OUTPUT_DIR=
